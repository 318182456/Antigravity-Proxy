{
  "name": "antigravity-proxy",
  "displayName": "Antigravity Proxy",
  "description": "Windows 透明代理注入工具 — 为 Antigravity 助手提供全流程自动化代理方案（内置中继、hosts 劫持、状态监控）。",
  "version": "0.0.3",
  "publisher": "318182456",
  "author": "318182456",
  "repository": {
    "type": "git",
    "url": "https://github.com/318182456/Antigravity-Proxy.git"
  },
  "bugs": {
    "url": "https://github.com/318182456/Antigravity-Proxy/issues"
  },
  "homepage": "https://github.com/318182456/Antigravity-Proxy",
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "proxy",
    "socks5",
    "windows",
    "transparent-proxy",
    "antigravity",
    "clash",
    "v2ray"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "antigravity-proxy.start",
        "title": "🚀 启动代理",
        "category": "Antigravity Proxy"
      },
      {
        "command": "antigravity-proxy.stop",
        "title": "⏹ 停止代理",
        "category": "Antigravity Proxy"
      },
      {
        "command": "antigravity-proxy.showLog",
        "title": "📋 查看日志",
        "category": "Antigravity Proxy"
      },
      {
        "command": "antigravity-proxy.openSettings",
        "title": "⚙️ 打开配置页面",
        "category": "Antigravity Proxy"
      },
      {
        "command": "antigravity-proxy.openDiagnostics",
        "title": "📊 环境诊断与状态",
        "category": "Antigravity Proxy"
      },
      {
        "command": "antigravity-proxy.testUpstreamProxy",
        "title": "🔌 检测上游代理（TCP + SOCKS5）",
        "category": "Antigravity Proxy"
      },
      {
        "command": "antigravity-proxy.prepareEnvironment",
        "title": "🔄 重新启动特权服务（写入 hosts 并重启中继）",
        "category": "Antigravity Proxy"
      },
      {
        "command": "antigravity-proxy.cleanupEnvironment",
        "title": "🧹 清理 hosts 与中继",
        "category": "Antigravity Proxy"
      },
      {
        "command": "antigravity-proxy.restoreNoProxy",
        "title": "🔕 完全停用代理（恢复 hosts/中继）",
        "category": "Antigravity Proxy"
      }
    ],
    "configuration": {
      "title": "Antigravity Proxy",
      "properties": {
        "antigravity-proxy.proxyHost": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "代理服务器地址"
        },
        "antigravity-proxy.proxyPort": {
          "type": "number",
          "default": 7890,
          "description": "代理服务器端口"
        },
        "antigravity-proxy.proxyType": {
          "type": "string",
          "enum": [
            "socks5",
            "http"
          ],
          "default": "socks5",
          "description": "代理类型"
        },
        "antigravity-proxy.timeout": {
          "type": "number",
          "default": 5000,
          "description": "连接超时（毫秒）"
        },
        "antigravity-proxy.antigravityAppPath": {
          "type": "string",
          "default": "",
          "description": "Antigravity IDE.exe / Antigravity.exe 安装路径（留空自动检测）"
        },
        "antigravity-proxy.autoStart": {
          "type": "boolean",
          "default": false,
          "description": "启动时自动开启代理"
        },
        "antigravity-proxy.autoPrepareHostsRelay": {
          "type": "boolean",
          "default": true,
          "description": "Windows 激活后，若检测到 hosts 或本地中继未就绪，自动执行「重新启动」写入 hosts 并重启中继。"
        },
        "antigravity-proxy.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "在状态栏右侧显示「AG-Proxy」运行状态（绿/黄/红）。关闭后不占用状态栏，扩展功能仍可通过命令面板与配置页使用。"
        },
        "antigravity-proxy.refreshQuotaWhenReady": {
          "type": "boolean",
          "default": true,
          "description": "额度充沛，处于就绪状态时，调用ai 刷新额度"
        },
        "antigravity-proxy.refreshStartTime": {
          "type": "integer",
          "default": 5,
          "description": "自动刷新额度周期的开始时间（小时，0-23）"
        },
        "antigravity-proxy.refreshEndTime": {
          "type": "integer",
          "default": 24,
          "description": "自动刷新额度周期的结束时间（小时，1-24）"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {}
}